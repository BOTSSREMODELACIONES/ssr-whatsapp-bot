    const blob = new Blob([html], { type: "text/html;charset=utf-8" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url; a.download = `${client.referencia}_cotizacion.html`;
    document.body.appendChild(a); a.click();
    setTimeout(() => { document.body.removeChild(a); URL.revokeObjectURL(url); }, 100);
  }

  const S = styles;

  return (
    <div style={S.root}>
      {/* Header */}
      <div style={S.header}>
        <div style={S.headerLeft}>
          <div style={S.logo}>SS</div>
          <div>
            <div style={S.headerTitle}>Agente de Cotizaciones</div>
            <div style={S.headerSub}>SS Remodelaciones — Sistema automático</div>
          </div>
        </div>
        <div style={{ display: "flex", gap: 8 }}>
          {["Datos", "Procesando", "Revisión", "Exportar"].map((s, i) => {
            const stepMap = ["input", "processing", "review", "export"];
            const active = step === stepMap[i];
            const done = ["input", "processing", "review", "export"].indexOf(step) > i;
            return (
              <div key={s} style={{ ...S.stepDot, background: active ? "#1B3A6B" : done ? "#2ECC71" : "#e0e0e0", color: active || done ? "white" : "#aaa" }}>
                {done ? "✓" : i + 1}
              </div>
            );
          })}
        </div>
      </div>

      <div style={S.body}>
        {/* STEP 1: INPUT */}
        {step === "input" && (
          <div>
            <div style={S.sectionTitle}>Información del cliente</div>
            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 12, marginBottom: 20 }}>
              {[
                ["Nombre / Empresa", "nombre", "Nathalie Alpízar"],
                ["Email", "email", "cliente@email.com"],
                ["Teléfono", "telefono", "+506 8888-0000"],
                ["N° Referencia", "referencia", "REF-037-26"],
                ["Asunto (se autogenera)", "asunto", "Remodelación baño..."],
              ].map(([label, field, ph]) => (
                <div key={field}>
                  <div style={S.label}>{label}</div>
                  <input value={client[field]} onChange={e => setClient(c => ({ ...c, [field]: e.target.value }))} placeholder={ph}
                    style={S.input} />
                </div>
              ))}
            </div>

            <div style={S.sectionTitle}>Notas de la visita</div>
            <div style={{ fontSize: 12, color: "#888", marginBottom: 8 }}>
              Escribí o dictá exactamente lo que anotó Melvin en la visita. Cuanto más detalle, más precisa la cotización.
            </div>
            <textarea
              value={notas}
              onChange={e => setNotas(e.target.value)}
              rows={12}
              placeholder={`Ejemplo:\nCliente: Nathalie, baño principal en San Francisco de Heredia\n\n- Demoler tina existente y reparar el piso, zona de unos 2m2\n- Cambiar todo el enchape del baño, paredes y piso, aprox 19m2. Cerámica tipo KEROS o similar de EPA\n- Fabricar mueble de baño melamina blanca 80cm con lavamanos sobre el mueble\n- Instalar mampara de vidrio 6mm y puerta de vidrio con accesorios inox para la ducha nueva\n- Bote de escombros y transporte de materiales\n\nObservaciones: baño en buen estado general, problema principal es la tina que quieren eliminar.`}
              style={{ ...S.input, resize: "vertical", fontFamily: "monospace", fontSize: 13, lineHeight: 1.6 }}
            />

            {error && <div style={S.error}>{error}</div>}

            <button onClick={procesar} style={S.btnPrimary}>
              → Procesar notas y buscar precios
            </button>
          </div>
        )}

        {/* STEP 2: PROCESSING */}
        {step === "processing" && (
          <div style={{ textAlign: "center", padding: "60px 20px" }}>
            <div style={{ fontSize: 32, marginBottom: 20 }}>⟳</div>
            <div style={{ fontSize: 16, fontWeight: 600, color: "#1B3A6B", marginBottom: 8 }}>{loadMsg}</div>
            <div style={{ fontSize: 13, color: "#aaa" }}>Buscando precios en Construplaza, EPA y El Lagar...</div>
            <div style={{ marginTop: 24, height: 4, background: "#eee", borderRadius: 2, overflow: "hidden" }}>
              <div style={{ height: "100%", background: "#1B3A6B", animation: "progress 3s ease-in-out infinite", width: "60%", borderRadius: 2 }} />
            </div>
            <style>{`@keyframes progress{0%{transform:translateX(-100%)}100%{transform:translateX(200%)}}`}</style>
          </div>
        )}

        {/* STEP 3: REVIEW */}
        {step === "review" && (
          <div>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 16 }}>
              <span style={S.sectionTitle}>Revisión del presupuesto</span>
              <div style={{ display: "flex", gap: 8 }}>
                <button onClick={() => setStep("input")} style={S.btnSecondary}>← Volver</button>
                <button onClick={() => setStep("export")} style={S.btnPrimary}>Aprobar y exportar →</button>
              </div>
            </div>

            {/* Client summary */}
            <div style={{ ...S.card, marginBottom: 16, display: "grid", gridTemplateColumns: "repeat(4,1fr)", gap: 12 }}>
              {[["Ref", client.referencia], ["Cliente", client.nombre], ["Fecha", new Date().toLocaleDateString("es-CR")], ["Total", fmt(total)]].map(([k, v]) => (
                <div key={k}><div style={S.label}>{k}</div><div style={{ fontWeight: 600, color: "#1B3A6B" }}>{v}</div></div>
              ))}
            </div>

            {items.map((item, ii) => (
              <div key={item.id} style={{ ...S.card, marginBottom: 12 }}>
                <div style={{ display: "grid", gridTemplateColumns: "3fr 1fr 1fr 1fr 1fr 1fr", gap: 8, marginBottom: 10, alignItems: "end" }}>
                  <div>
                    <div style={S.label}>Actividad {item.id}</div>
                    <input value={item.descripcion} onChange={e => updateItem(ii, "descripcion", e.target.value)} style={S.inputSm} />
                  </div>
                  {[["Und", "unidad"], ["Días", "dias"], ["Operarios", "operarios"], ["Ayudantes", "ayudantes"]].map(([l, f]) => (
                    <div key={f}>
                      <div style={S.label}>{l}</div>
                      <input value={item[f]} onChange={e => updateItem(ii, f, e.target.value)} style={{ ...S.inputSm, width: "100%" }} />
                    </div>
                  ))}
                  <div>
                    <div style={S.label}>Total MO</div>
                    <div style={{ fontSize: 13, fontWeight: 600, color: "#555", paddingTop: 8 }}>{fmt(item.moTotal)}</div>
                  </div>
                </div>

                {/* Materiales */}
                <table style={{ width: "100%", fontSize: 12, borderCollapse: "collapse" }}>
                  <thead>
                    <tr style={{ background: "#f5f7fb" }}>
                      {["Material", "Und", "Cantidad", "P. Unitario", "Subtotal", "Fuente", ""].map(h => (
                        <th key={h} style={{ textAlign: "left", padding: "5px 8px", color: "#555", fontWeight: 500 }}>{h}</th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {item.materiales.map((m, mi) => (
                      <tr key={mi} style={{ borderBottom: "1px solid #eee" }}>
                        <td style={{ padding: "4px 6px" }}><input value={m.detalle} onChange={e => updateMaterial(ii, mi, "detalle", e.target.value)} style={S.inputXs} /></td>
                        <td style={{ padding: "4px 6px" }}><input value={m.und} onChange={e => updateMaterial(ii, mi, "und", e.target.value)} style={{ ...S.inputXs, width: 50 }} /></td>
                        <td style={{ padding: "4px 6px" }}><input type="number" value={m.cantidad} onChange={e => updateMaterial(ii, mi, "cantidad", e.target.value)} style={{ ...S.inputXs, width: 70 }} /></td>
                        <td style={{ padding: "4px 6px" }}><input type="number" value={m.precio_unitario} onChange={e => updateMaterial(ii, mi, "precio_unitario", e.target.value)} style={{ ...S.inputXs, width: 90 }} /></td>
                        <td style={{ padding: "4px 6px", fontWeight: 600, color: "#1B3A6B" }}>{fmt(m.cantidad * m.precio_unitario)}</td>
                        <td style={{ padding: "4px 6px" }}>
                          <select value={m.fuente} onChange={e => updateMaterial(ii, mi, "fuente", e.target.value)} style={S.inputXs}>
                            {["Construplaza", "EPA", "El Lagar", "Estimado"].map(f => <option key={f}>{f}</option>)}
                          </select>
                        </td>
                        <td><button onClick={() => removeMaterial(ii, mi)} style={{ background: "none", border: "none", color: "#e74c3c", cursor: "pointer", fontSize: 14 }}>✕</button></td>
                      </tr>
                    ))}
                  </tbody>
                </table>
                <div style={{ display: "flex", justifyContent: "space-between", marginTop: 8 }}>
                  <button onClick={() => addMaterial(ii)} style={{ ...S.btnSecondary, fontSize: 12, padding: "4px 10px" }}>+ Material</button>
                  <div style={{ fontSize: 13 }}>Mat: <b>{fmt(item.matTotal)}</b> | MO: <b>{fmt(item.moTotal)}</b> | <span style={{ color: "#1B3A6B", fontWeight: 700 }}>Total: {fmt(item.subtotal)}</span></div>
                </div>
              </div>
            ))}

            {/* Totales */}
            <div style={{ ...S.card, maxWidth: 420, marginLeft: "auto" }}>
              {[
                ["Subtotal materiales (inc. 5% gestión)", subtotalMat],
                ["Subtotal M.O.", subtotalMO],
                ["Sub total", subtotal],
                ["Imprevistos 5%", imprevistos],
                ["Base imponible", baseImponible],
                ["IVA 13%", iva],
                ["Reembolso visita", -25000]
              ].map(([k, v]) => (
                <div key={k} style={{ display: "flex", justifyContent: "space-between", padding: "4px 0", fontSize: 13, borderBottom: "1px solid #eee" }}>
                  <span style={{ color: "#666" }}>{k}</span><span style={{ fontWeight: k === "Sub total" || k === "Base imponible" ? 600 : 400 }}>{fmt(v)}</span>
                </div>
              ))}
              <div style={{ display: "flex", justifyContent: "space-between", padding: "8px 0", fontSize: 16, fontWeight: 700, color: "#1B3A6B" }}>
                <span>TOTAL</span><span>{fmt(total)}</span>
              </div>
            </div>
          </div>
        )}

        {/* STEP 4: EXPORT */}
        {step === "export" && (
          <div>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 20 }}>
              <div style={S.sectionTitle}>Exportar documentos</div>
              <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
                <button onClick={() => setStep("review")} style={{ ...S.btnSecondary, marginTop: 0 }}>← Editar</button>
                <button onClick={guardarEnDrive} disabled={saving} style={{ ...S.btnPrimary, background: saving ? "#aaa" : "#C8922A", marginTop: 0, cursor: saving ? "not-allowed" : "pointer" }}>
                  {saving ? "⟳ Guardando..." : "☁ Drive + WhatsApp"}
                </button>
                <button onClick={descargarExcel} style={{ ...S.btnPrimary, background: "#1E8449", marginTop: 0 }}>↓ Excel</button>
                <button onClick={descargarWordHTML} style={{ ...S.btnPrimary, background: "#1B3A6B", marginTop: 0 }}>↓ Word (HTML)</button>
              </div>
            </div>

            {/* Resultado Drive */}
            {driveResult && (
              <div style={{ background: "#f0fff4", border: "1px solid #2ECC71", borderRadius: 8, padding: "14px 18px", marginBottom: 16, fontSize: 13 }}>
                <div style={{ fontWeight: 700, color: "#1E8449", marginBottom: 6 }}>✅ Guardado en Drive — WhatsApp enviado a Darwin</div>
                <div>📁 <a href={driveResult.carpeta} target="_blank" rel="noreferrer" style={{ color: "#1B3A6B" }}>Abrir carpeta en Drive</a></div>
                <div style={{ marginTop: 4 }}>💰 Total: <b>{driveResult.total}</b></div>
              </div>
            )}
            {driveError && (
              <div style={{ background: "#fff5f5", border: "1px solid #e74c3c", borderRadius: 8, padding: "14px 18px", marginBottom: 16, fontSize: 12 }}>
                <div style={{ fontWeight: 700, color: "#c0392b", marginBottom: 4 }}>❌ Error al guardar en Drive:</div>
                <div style={{ fontFamily: "monospace", color: "#555" }}>{driveError}</div>
                <div style={{ marginTop: 6, color: "#888" }}>Revisá los logs de Railway para más detalles.</div>
              </div>
            )}

            {/* Word Preview */}
            <div id="word-preview" ref={previewRef} style={{ background: "white", padding: "40px 50px", border: "1px solid #ddd", borderRadius: 4, fontFamily: "Arial, sans-serif", fontSize: "11pt", color: "#000", lineHeight: 1.5 }}>
              {/* Header */}
              <table style={{ width: "100%", borderCollapse: "collapse", marginBottom: 16 }}>
                <tbody>
                  <tr>
                    <td style={{ width: 160, verticalAlign: "middle" }}>
                      <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                        <div style={{ width: 44, height: 44, background: "#C8922A", borderRadius: 6, display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 900, fontSize: 16, color: "white" }}>SS</div>
                        <div>
                          <div style={{ fontWeight: 800, fontSize: 15, color: "#1B3A6B", lineHeight: 1.1 }}>SS REMODELACIONES</div>
                          <div style={{ fontSize: 9, color: "#888" }}>Solo Senso S.A.</div>
                        </div>
                      </div>
                    </td>
                    <td style={{ fontSize: 10, color: "#333" }}>
                      <b>Solo Senso Sociedad Anónima</b><br />
                      San Isidro de Heredia | Tel: (506) 7006-8477 / 6205-2075<br />
                      gerencia@ssremodelaciones.com | www.ssremodelaciones.com
                    </td>
                  </tr>
                </tbody>
              </table>

              <table style={{ width: "100%", borderCollapse: "collapse", marginBottom: 12, fontSize: 10 }}>
                <tbody>
                  <tr>
                    <td style={{ border: "1px solid #ccc", padding: "4px 8px" }}><b>Fecha:</b> {new Date().toLocaleDateString("es-CR")}</td>
                    <td style={{ border: "1px solid #ccc", padding: "4px 8px" }}><b>Ref.:</b> {client.referencia}</td>
                  </tr>
                  <tr>
                    <td style={{ border: "1px solid #ccc", padding: "4px 8px" }} colSpan={2}>
                      <b>Dirigido a:</b> {client.nombre} &nbsp;&nbsp;
                      {client.email && <><b>Email:</b> {client.email} &nbsp;&nbsp;</>}
                      {client.telefono && <><b>Tel:</b> {client.telefono}</>}
                    </td>
                  </tr>
                  <tr>
                    <td style={{ border: "1px solid #ccc", padding: "4px 8px" }} colSpan={2}><b>Asunto:</b> {client.asunto}</td>
                  </tr>
                </tbody>
              </table>

              <p>Estimado/a <b>{client.nombre}</b>;</p>
              <p>Atendiendo a su solicitud, anexo la propuesta correspondiente a: <b>{client.asunto}</b>.</p>

              <h3 style={{ color: "#1B3A6B", fontSize: 12 }}>DETALLES DE LA OFERTA</h3>
              <p><b>Los trabajos incluidos en esta propuesta comprenden:</b></p>
              <ul style={{ margin: "6px 0 12px 0", paddingLeft: 20 }}>
                {items.map(i => <li key={i.id} style={{ marginBottom: 3 }}>{i.descripcion}</li>)}
              </ul>

              <table style={{ width: "100%", borderCollapse: "collapse", marginBottom: 12 }}>
                <thead>
                  <tr style={{ background: "#1B3A6B" }}>
                    {["Descripción", "Unidad", "Cantidad", "Materiales", "M.O.", "SUB TOTAL"].map(h => (
                      <th key={h} style={{ color: "white", padding: "6px 8px", fontSize: 10, textAlign: h === "Descripción" ? "left" : "right" }}>{h}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {items.map((i, idx) => (
                    <tr key={i.id} style={{ background: idx % 2 ? "#f5f7fb" : "white" }}>
                      <td style={{ border: "1px solid #ddd", padding: "5px 8px", fontSize: 10 }}>{i.descripcion}</td>
                      <td style={{ border: "1px solid #ddd", padding: "5px 8px", fontSize: 10, textAlign: "center" }}>{i.unidad}</td>
                      <td style={{ border: "1px solid #ddd", padding: "5px 8px", fontSize: 10, textAlign: "right" }}>{i.cantidad?.toLocaleString()}</td>
                      <td style={{ border: "1px solid #ddd", padding: "5px 8px", fontSize: 10, textAlign: "right" }}>{fmt(i.matTotal)}</td>
                      <td style={{ border: "1px solid #ddd", padding: "5px 8px", fontSize: 10, textAlign: "right" }}>{fmt(i.moTotal)}</td>
                      <td style={{ border: "1px solid #ddd", padding: "5px 8px", fontSize: 10, textAlign: "right", fontWeight: 600 }}>{fmt(i.subtotal)}</td>
                    </tr>
                  ))}
                  {[
                    ["Sub total", subtotal],
                    ["Imprevistos 5%", imprevistos],
                    ["Base imponible", baseImponible],
                    ["IVA 13%", iva],
                    ["Reembolso pago de visita", -25000]
                  ].map(([k, v]) => (
                    <tr key={k}>
                      <td colSpan={5} style={{ border: "1px solid #ddd", padding: "4px 8px", fontSize: 10, textAlign: "right", fontWeight: k === "Base imponible" ? 600 : 400 }}>{k}</td>
                      <td style={{ border: "1px solid #ddd", padding: "4px 8px", fontSize: 10, textAlign: "right", fontWeight: k === "Base imponible" ? 600 : 400 }}>{fmt(v)}</td>
                    </tr>
                  ))}
                  <tr style={{ background: "#1B3A6B" }}>
                    <td colSpan={5} style={{ padding: "6px 8px", fontSize: 11, textAlign: "right", color: "white", fontWeight: 700 }}>TOTAL</td>
                    <td style={{ padding: "6px 8px", fontSize: 11, textAlign: "right", color: "white", fontWeight: 700 }}>{fmt(total)}</td>
                  </tr>
                </tbody>
              </table>

              <h3 style={{ color: "#1B3A6B", fontSize: 12 }}>C) CONDICIONES DE LA OFERTA</h3>
              <ul style={{ fontSize: 10, paddingLeft: 20, lineHeight: 1.7 }}>
                <li>Todos los pagos mediante transferencia bancaria a cuentas de SS Remodelaciones.</li>
                <li>Para iniciar obras se requiere aprobación por escrito de los trabajos cotizados.</li>
                <li><b>Forma de pago:</b> 60% para iniciar, 10% semanal (viernes) hasta finalizar, saldo al terminar.</li>
                <li>No incluye costos de reparaciones ocultas no contempladas en esta cotización.</li>
                <li>Vigencia de la cotización: <b>15 días hábiles</b>.</li>
              </ul>

              <p style={{ fontSize: 10, marginTop: 8 }}><b>Garantía:</b> SS Remodelaciones ofrece garantía de <b>12 meses por desperfecto en la instalación</b>, a partir de la fecha de entrega y firma de recibido del cliente.</p>

              <h3 style={{ color: "#1B3A6B", fontSize: 12 }}>DATOS BANCARIOS</h3>
              <p style={{ fontSize: 10 }}>
                <b>BAC Colones</b> | Nombre: Solo Senso SA | Cédula: 3-101-435423<br />
                Cuenta corriente: 938419603 | IBAN: CR29010200009384196033<br />
                Email notif.: gerencia@ssremodelaciones.com
              </p>

              <div style={{ marginTop: 30, display: "flex", justifyContent: "space-between", fontSize: 10 }}>
                <div style={{ textAlign: "center", width: "40%" }}>
                  <div style={{ borderTop: "1px solid #333", paddingTop: 4 }}>Ing. Darwin J. Guillón M.<br /><b>Gerente General</b></div>
                </div>
                <div style={{ textAlign: "center", width: "40%" }}>
                  <div style={{ borderTop: "1px solid #333", paddingTop: 4 }}>{client.nombre}<br /><b>Cliente</b></div>
                </div>
              </div>

              <table style={{ width: "100%", marginTop: 20, borderTop: "2px solid #1B3A6B" }}>
                <tbody>
                  <tr>
                    <td style={{ fontSize: 9, color: "#555", paddingTop: 6 }}>WWW.SSREMODELACIONES.COM | @ssremodelaciones | Tel: 7006-8477 | gerencia@ssremodelaciones.com</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

const styles = {
  root: { fontFamily: "'Segoe UI', Arial, sans-serif", background: "#F4F6F9", minHeight: "100vh" },
  header: { background: "#1B3A6B", padding: "14px 24px", display: "flex", alignItems: "center", justifyContent: "space-between" },
  headerLeft: { display: "flex", alignItems: "center", gap: 12 },
  logo: { width: 36, height: 36, background: "#C8922A", borderRadius: 4, display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 700, color: "white", fontSize: 14 },
  headerTitle: { color: "white", fontWeight: 600, fontSize: 15 },
  headerSub: { color: "rgba(255,255,255,0.6)", fontSize: 11 },
  stepDot: { width: 26, height: 26, borderRadius: "50%", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 11, fontWeight: 600, transition: "all .2s" },
  body: { maxWidth: 1000, margin: "0 auto", padding: "24px 20px" },
  sectionTitle: { fontSize: 14, fontWeight: 600, color: "#1B3A6B", marginBottom: 12, borderBottom: "2px solid #C8922A", paddingBottom: 6, display: "block" },
  card: { background: "white", borderRadius: 8, padding: "16px 18px", boxShadow: "0 1px 4px rgba(0,0,0,0.08)" },
  label: { fontSize: 11, color: "#888", marginBottom: 4, textTransform: "uppercase", letterSpacing: "0.05em" },
  input: { width: "100%", border: "1px solid #ddd", borderRadius: 6, padding: "9px 12px", fontSize: 13, outline: "none", background: "white", color: "#222" },
  inputSm: { width: "100%", border: "1px solid #ddd", borderRadius: 4, padding: "6px 8px", fontSize: 12, outline: "none" },
  inputXs: { border: "1px solid #e5e5e5", borderRadius: 3, padding: "3px 6px", fontSize: 12, outline: "none", width: "100%" },
  btnPrimary: { background: "#1B3A6B", color: "white", border: "none", borderRadius: 6, padding: "10px 20px", fontSize: 13, cursor: "pointer", fontWeight: 600, marginTop: 16 },
  btnSecondary: { background: "white", color: "#1B3A6B", border: "1px solid #1B3A6B", borderRadius: 6, padding: "9px 18px", fontSize: 13, cursor: "pointer" },
  error: { background: "#ffeaea", border: "1px solid #f5c6c6", borderRadius: 6, padding: "10px 14px", color: "#c0392b", fontSize: 13, marginTop: 12 },
};
