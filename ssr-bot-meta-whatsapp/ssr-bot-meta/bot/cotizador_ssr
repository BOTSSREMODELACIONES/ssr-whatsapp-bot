    <table style="border:none;width:100%"><tr>
      <td style="border:none;width:45%;text-align:center;border-top:1px solid #333;padding-top:4px">Ing. Darwin J. Guilon M.<br><b>Gerente General</b></td>
      <td style="border:none;width:10%"></td>
