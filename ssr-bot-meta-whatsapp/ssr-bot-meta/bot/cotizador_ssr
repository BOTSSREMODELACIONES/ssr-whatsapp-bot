        <td align="right">${i.cantidad||1}</td>
        <td align="right">${fmt(i.matTotal)}</td>
        <td align="right">${fmt(i.moTotal)}</td>
        <td align="right"><b>${fmt(i.subtotal)}</b></td>
      </tr>`).join("");
    const totalesRows = [
      ["Sub total", subtotal, "total-row", false],
      ["Imprevistos 5%", imprevistos, "total-row", false],
      ["Base imponible", baseImponible, "base-row", true],
      ["IVA 13%", iva, "total-row", false],
      ["Reembolso pago de visita", -25000, "total-row", false]
    ].map(([k,v,cls]) => `<tr class="${cls}"><td colspan="5" align="right">${k}</td><td align="right">${fmt(v)}</td></tr>`).join("");
    const lista = items.map(i => `<li>${i.descripcion}</li>`).join("");
    const html = `<!DOCTYPE html><html><head><meta charset="utf-8"><title>${client.referencia}</title>
