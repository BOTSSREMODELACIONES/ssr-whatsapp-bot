const ACCENT_MAP = {
  remodelacion: 'remodelación', Remodelacion: 'Remodelación',
  ceramica:     'cerámica',     Ceramica:     'Cerámica',
  demolicion:   'demolición',   Demolicion:   'Demolición',
  instalacion:  'instalación',  Instalacion:  'Instalación',
  colocacion:   'colocación',   Colocacion:   'Colocación',
  fabricacion:  'fabricación',  Fabricacion:  'Fabricación',
  descripcion:  'descripción',  condicion:    'condición',
  garantia:     'garantía',     numero:       'número',
  tuberia:      'tubería',      cotizacion:   'cotización',
  reparacion:   'reparación',   instalacion:  'instalación',
};
function fixSpanish(text = '') {
  return Object.entries(ACCENT_MAP).reduce(
    (s, [bad, good]) => s.replace(new RegExp(`\\b${bad}\\b`, 'g'), good), text
  );
}

// ── Auth Google Drive ─────────────────────────────────────────────────────────
async function getDriveClient() {
  const credentials = JSON.parse(process.env.GOOGLE_SERVICE_ACCOUNT);
  const auth = new google.auth.JWT({
    email:   credentials.client_email,
    key:     credentials.private_key,
    scopes:  ["https://www.googleapis.com/auth/drive"],
    subject: DARWIN_EMAIL,
  });
  return google.drive({ version: "v3", auth });
}

async function getLogoBuffer(drive) {
  try {
    const r = await drive.files.get({ fileId: LOGO_DRIVE_FILE_ID, alt: "media" }, { responseType: "arraybuffer" });
    return Buffer.from(r.data);
  } catch (e) { console.warn("⚠️ Logo no descargado:", e.message); return null; }
}

async function transferirOwnership(drive, fileId) {
  try {
    await drive.permissions.create({
      fileId, requestBody: { role: "owner", type: "user", emailAddress: DARWIN_EMAIL },
      transferOwnership: true, moveToNewOwnersRoot: false,
    });
  } catch (e) { console.warn(`⚠️ Ownership de ${fileId}:`, e.message); }
}

async function getNextRef(drive) {
  try {
    const year = new Date().getFullYear().toString().slice(-2);
    const res  = await drive.files.list({
      q: `'${DRIVE_FOLDER_2026}' in parents and mimeType='application/vnd.google-apps.folder' and trashed=false`,
      fields: "files(name)", orderBy: "name desc", pageSize: 20,
      supportsAllDrives: true, includeItemsFromAllDrives: true,
    });
    const folders = res.data.files || [];
    let maxNum = 0;
    for (const f of folders) {
      const m = f.name.match(/^REF-(\d+)-/);
      if (m && parseInt(m[1]) > maxNum) maxNum = parseInt(m[1]);
    }
    return `REF-${String(maxNum + 1).padStart(3, "0")}-${year}`;
  } catch (e) {
    const year = new Date().getFullYear().toString().slice(-2);
    return `REF-${Math.floor(Math.random() * 900) + 100}-${year}`;
  }
}

// ── Generar Excel ─────────────────────────────────────────────────────────────
// FIX #16: Hoja Detalle Interno con fórmulas (tracking de filas durante la construcción)
function generarExcel(client, items) {
  const wb    = XLSX.utils.book_new();
  const T     = calcTotals(items);
  const fecha = new Date().toLocaleDateString("es-CR");
  const n     = items.length;

  // ── Hoja 1: Detalle interno completo ──
  const rows = [
    ["SS REMODELACIONES — PRESUPUESTO INTERNO (CONFIDENCIAL)"],
    ["Ref:", client.referencia, "Fecha:", fecha, "Cliente:", client.nombre],
    ["Proyecto:", client.asunto],
    [],
    ["Ítem","Detalle","Und","Cant","Días","Op","Ay","Mat.Base","Mat+5%","MO","Utilidad","Total MO","TOTAL"],
  ];

  // FIX #16: acumular info de filas para asignar fórmulas después
  const ws1Tracks = []; // { mainRow, subStart, subEnd, subtotalRow, item }

  items.forEach(item => {
    const mainRow = rows.length + 1;                    // Excel 1-indexed
    const matBase = Math.round(item.matTotal / (1 + MAT_OVERHEAD));
    rows.push([
      item.id, item.descripcion, item.unidad || "", item.cantidad || 1,
      item.dias, item.operarios, item.ayudantes,
      matBase, item.matTotal,
      item.moBase, item.moUtilidad, item.moTotal, item.subtotal,
    ]);

    const subStart = rows.length + 1;
    (item.materiales || []).forEach(m =>
      rows.push(["", ` ➳ ${m.detalle} (${m.fuente})`, m.und, m.cantidad, m.precio_unitario,
                 (m.cantidad||0)*(m.precio_unitario||0)])
    );
    const subEnd = rows.length;

    const subtotalRow = rows.length + 1;
    rows.push(["", "Subtotal mat:", "", "", "", "", "", "", item.matTotal]);
    rows.push([]);

    ws1Tracks.push({ mainRow, subStart, subEnd, subtotalRow, item });
  });

  rows.push(["", "TOTAL MATERIALES", "", "", "", "", "", "", T.subtotalMat, "", "", "TOTAL M.O.", T.subtotalMO]);
  rows.push([]);
  const s = {};
  s.subtotal    = rows.length + 1; rows.push(["", "Sub total",             "", "", "", "", "", "", "", T.subtotal]);
  s.imprevistos = rows.length + 1; rows.push(["", "Imprevistos 5% (INT.)", "", "", "", "", "", "", "", T.imprevistos]);
  s.base        = rows.length + 1; rows.push(["", "Base imponible",        "", "", "", "", "", "", "", T.baseImponible]);
  s.iva         = rows.length + 1; rows.push(["", "IVA 13%",               "", "", "", "", "", "", "", T.iva]);
  s.reembolso   = rows.length + 1; rows.push(["", "Reembolso visita",      "", "", "", "", "", "", "", -REEMBOLSO_VISITA]);
  s.total       = rows.length + 1; rows.push(["", "TOTAL",                 "", "", "", "", "", "", "", T.total]);

  const ws1 = XLSX.utils.aoa_to_sheet(rows);
  ws1["!cols"] = [{wch:6},{wch:45},{wch:8},{wch:6},{wch:6},{wch:4},{wch:4},{wch:12},{wch:12},{wch:12},{wch:12},{wch:12},{wch:14}];

  // FIX #16: asignar fórmulas en ws1 (Detalle Interno)
  ws1Tracks.forEach(({ mainRow, subStart, subEnd, subtotalRow, item }) => {
    // Sub-ítems: F = D*E
    for (let r = subStart; r <= subEnd; r++) {
      ws1[`F${r}`] = { t: "n", v: (ws1[`D${r}`]?.v||0) * (ws1[`E${r}`]?.v||0), f: `D${r}*E${r}` };
    }
    // Main item: I = H*1.05 | K = J*0.5 | L = J+K | M = I+L
    ws1[`I${mainRow}`] = { t: "n", v: item.matTotal,   f: `H${mainRow}*1.05` };
    ws1[`K${mainRow}`] = { t: "n", v: item.moUtilidad, f: `J${mainRow}*0.5` };
    ws1[`L${mainRow}`] = { t: "n", v: item.moTotal,    f: `J${mainRow}+K${mainRow}` };
    ws1[`M${mainRow}`] = { t: "n", v: item.subtotal,   f: `I${mainRow}+L${mainRow}` };
    // Subtotal mat: I = SUM(F_subs)
    if (subStart <= subEnd) {
      ws1[`I${subtotalRow}`] = { t: "n", v: item.matTotal, f: `SUM(F${subStart}:F${subEnd})*1.05` };
    }
  });
  // Fórmulas en resumen de hoja 1
  const mainRows = ws1Tracks.map(t => `M${t.mainRow}`).join('+');
  ws1[`J${s.subtotal}`]    = { t: "n", v: T.subtotal,       f: mainRows };
  ws1[`J${s.imprevistos}`] = { t: "n", v: T.imprevistos,    f: `ROUND(J${s.subtotal}*0.05,0)` };
  ws1[`J${s.base}`]        = { t: "n", v: T.baseImponible,  f: `J${s.subtotal}+J${s.imprevistos}` };
  ws1[`J${s.iva}`]         = { t: "n", v: T.iva,            f: `ROUND(J${s.base}*0.13,0)` };
  ws1[`J${s.total}`]       = { t: "n", v: T.total,          f: `J${s.base}+J${s.iva}+J${s.reembolso}` };

  // ── Hoja 2: Resumen cliente (imprevistos absorbido en MO, con fórmulas) ──
  const resumen = [
    ["Descripción", "Unidad", "Cantidad", "Materiales", "M.O.", "SUB TOTAL"],
    ...T.itemsDisplay.map(i => [i.descripcion, i.unidad||"Und", i.cantidad||1, i.matTotal, i.moDisplay, i.subtotalDisplay]),
    [],
    ["", "", "", "", "Sub total",      T.subtotalDisplay],
    ["", "", "", "", "IVA 13%",        T.iva],
    ["", "", "", "", "Reembolso visita", -REEMBOLSO_VISITA],
    ["", "", "", "", "TOTAL",          T.total],
  ];

  const ws2 = XLSX.utils.aoa_to_sheet(resumen);
  ws2["!cols"] = [{wch:45},{wch:8},{wch:10},{wch:14},{wch:14},{wch:16}];

  // Fórmulas por ítem en hoja 2: SUB TOTAL (col F) = Mat (col D) + M.O. (col E)
  for (let fi = 0; fi < n; fi++) {
    const frow = fi + 2;
    ws2[`F${frow}`] = { t:"n", v: T.itemsDisplay[fi].subtotalDisplay, f: `D${frow}+E${frow}` };
  }

  // Fórmulas en totales (Resumen cliente)
  const sumRow = n + 3;
  ws2[`F${sumRow}`]   = { t:"n", v: T.subtotalDisplay, f: `SUM(F2:F${n+1})` };
  ws2[`F${sumRow+1}`] = { t:"n", v: T.iva,             f: `ROUND(F${sumRow}*0.13,0)` };
  ws2[`F${sumRow+3}`] = { t:"n", v: T.total,           f: `F${sumRow}+F${sumRow+1}+F${sumRow+2}` };

  XLSX.utils.book_append_sheet(wb, ws1, "Detalle Interno");
  XLSX.utils.book_append_sheet(wb, ws2, "Resumen Cotizacion");
  return XLSX.write(wb, { type: "buffer", bookType: "xlsx" });
}

