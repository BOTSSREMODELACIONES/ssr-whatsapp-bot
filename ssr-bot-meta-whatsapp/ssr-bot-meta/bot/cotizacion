// ── Crear carpeta en Drive ────────────────────────────────────────────────────
async function crearCarpetaDrive(client) {
  const drive = await getDriveClient();
  const nombreCliente = (client.nombre || "Cliente")
    .normalize("NFD").replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-zA-Z0-9\s]/g, "").replace(/\s+/g, "_").slice(0, 30);
  const folderName = `${client.referencia}_${nombreCliente}`;

  const folder = await drive.files.create({
    requestBody: { name: folderName, mimeType: "application/vnd.google-apps.folder", parents: [DRIVE_FOLDER_2026] },
    fields: "id, name, webViewLink",
  });
  await transferirOwnership(drive, folder.data.id);
  return { id: folder.data.id, name: folderName, link: folder.data.webViewLink };
}

// ── Subir archivo a Drive ─────────────────────────────────────────────────────
async function subirArchivo(drive, folderId, nombre, buffer, mimeType) {
  const { Readable } = require("stream");
  const file = await drive.files.create({
    requestBody: { name: nombre, parents: [folderId] },
    media: { mimeType, body: Readable.from(buffer) },
    fields: "id, name, webViewLink",
  });
  await transferirOwnership(drive, file.data.id);
  return file.data;
}

// ── HTML Snapshot editable ────────────────────────────────────────────────────
function generarHTMLSnapshot(client, items) {
  try {
    const htmlPath = path.join(__dirname, "..", "public", "cotizador.html");
    if (!fs.existsSync(htmlPath)) return null;
    let html = fs.readFileSync(htmlPath, "utf-8");

    const itemsCalc = items.map(item => {
      const mats      = item.materiales || [];
      const matBase   = mats.reduce((s, m) => s + (+m.cantidad) * (+m.precio_unitario), 0);
      const matTotal  = Math.round(matBase * 1.05);
      const moBase    = (+item.dias||1) * ((+item.operarios||1)*COST_OP + (+item.ayudantes||0)*COST_AY);
      const moUtilidad = moBase * 0.5;
      const moTotal   = moBase + moUtilidad;
      return { ...item, matTotal, moBase, moUtilidad, moTotal, subtotal: matTotal + moTotal };
    });

    const script = `<script>
window.PRELOADED_STATE = ${JSON.stringify({ step:2, client, notas:"", items:itemsCalc, fotos:[], pdfs:[], saving:false, driveOk:null, driveErr:null }, null, 2)};
</script>`;
    html = html.replace("</head>", script + "\n</head>");
    return Buffer.from(html, "utf-8");
  } catch (e) { console.warn("⚠️ HTML snapshot:", e.message); return null; }
}

// ── Proceso completo ──────────────────────────────────────────────────────────
async function procesarCotizacion({ client: clientInput, items: itemsInput }) {
  let client = { ...clientInput };
  console.log(`📋 Procesando cotización ${client.referencia} — ${client.nombre}`);

  try {
    // 1. REF real
    const drive0   = await getDriveClient();
    const refReal  = await getNextRef(drive0);
    client         = { ...client, referencia: refReal };
    console.log(`📋 REF asignado: ${refReal}`);

    // 2. FIX #11: Inyectar ítems obligatorios si no están ya
    const tieneOBL1 = (itemsInput || []).some(i => i.id === "OBL-1" || (i.descripcion||"").toLowerCase().includes("transporte de material"));
    const tieneOBL2 = (itemsInput || []).some(i => i.id === "OBL-2" || (i.descripcion||"").toLowerCase().includes("andamio"));

    let items = [...(itemsInput || [])];
    if (!tieneOBL1) items.push(calcItem(ITEMS_OBLIGATORIOS[0]));
    if (!tieneOBL2) items.push(calcItem(ITEMS_OBLIGATORIOS[1]));

    // 3. Logo
    const driveForLogo = await getDriveClient();
    const logoBuffer   = await getLogoBuffer(driveForLogo);

    // 4. Generar archivos
    console.log("⚙️  Generando Excel, Word y HTML snapshot...");
    const [excelBuffer, wordBuffer] = await Promise.all([
      Promise.resolve(generarExcel(client, items)),
      generarWord(client, items, logoBuffer),
    ]);

    // 5. Carpeta + subir
    const carpeta = await crearCarpetaDrive(client);
    const drive   = await getDriveClient();

    const uploads = [
      subirArchivo(drive, carpeta.id, `${refReal}_presupuesto_interno.xlsx`, excelBuffer,
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"),
      subirArchivo(drive, carpeta.id, `${refReal}_cotizacion_cliente.docx`, wordBuffer,
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document"),
    ];

    const htmlBuffer = generarHTMLSnapshot(client, items);
    if (htmlBuffer) uploads.push(subirArchivo(drive, carpeta.id, `${refReal}_cotizador_editable.html`, htmlBuffer, "text/html; charset=utf-8"));

    const archivos   = await Promise.all(uploads);
    const excelFile  = archivos[0];
    const wordFile   = archivos[1];
    const htmlFile   = archivos[2] || null;

    const { total } = calcTotals(items);

    // 6. Materiales a cotizar
    const aCotizar = [];
    for (const item of items) {
      for (const mat of (item.materiales || [])) {
        if (!mat.fuente || mat.fuente === "Cotizar") aCotizar.push(`• ${mat.detalle} (${item.descripcion})`);
      }
    }

    const lineasAlerta = aCotizar.length > 0
      ? ["", "⚠️ *Materiales sin precio — revisar antes de enviar:*", ...aCotizar]
      : ["", "✔️ Todos los materiales tienen precio de referencia."];

    const notif = [
      "✅ *Nueva cotización lista en Drive*", "",
      `📋 *${refReal}*`,
      `👤 Cliente: ${client.nombre}`,
      `🏗️ Proyecto: ${client.asunto}`,
      `💰 Total estimado: ${fmtCR(total)}`,
      ...lineasAlerta, "",
      `📁 Carpeta: ${carpeta.link}`, "",
      "_SS Remodelaciones — Sistema automático_",
    ].join("\n");

    await sendText(DARWIN_WHATSAPP, notif);
    await sendText(MELVIN_WHATSAPP, notif);
    console.log(`✅ Cotización ${refReal} procesada y notificada`);

    return {
      ok: true,
      referencia: refReal,
      carpeta:    carpeta.link,
      excel:      excelFile.webViewLink,
      word:       wordFile.webViewLink,
      html:       htmlFile ? htmlFile.webViewLink : null,
      total:      fmtCR(total),
    };

  } catch (err) {
    console.error("❌ Error procesando cotización:", err.message);
    throw err;
  }
}

module.exports = { procesarCotizacion };
