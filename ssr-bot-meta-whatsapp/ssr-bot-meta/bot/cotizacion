// ── Constantes ────────────────────────────────────────────────────────────────
const DRIVE_FOLDER_2026 = "1z3pmO0oMfY24PRSWwN4Kh1-1oqgXzPBG"; // Carpeta "2026" en SSR Cotizaciones
const DARWIN_EMAIL      = "proyectos@ssremodelaciones.com";       // ← email Google de Darwin (owner destino)
const IVA               = 0.13;
const MAT_OVERHEAD      = 0.05;
const IMPREVISTOS_PCT   = 0.05;
const DARWIN_WHATSAPP   = "+50683091817";
const MELVIN_WHATSAPP   = "+50671981370";

// ── Google Drive client — JWT Impersonation ──────────────────────────────────
// La SA actúa como proyectos@ssremodelaciones.com → archivos quedan en su Drive
// Requiere Domain-Wide Delegation en Google Workspace Admin:
//   admin.google.com → Seguridad → Controles de API → Delegación en todo el dominio
//   Agregar client_id de la SA con scope: https://www.googleapis.com/auth/drive
async function getDriveClient() {
  const credentials = JSON.parse(process.env.GOOGLE_SERVICE_ACCOUNT);
  const auth = new google.auth.JWT({
    email:   credentials.client_email,
    key:     credentials.private_key,
    scopes:  ["https://www.googleapis.com/auth/drive"],
    subject: "proyectos@ssremodelaciones.com",  // SA impersona esta cuenta
  });
  return google.drive({ version: "v3", auth });
}

// ── Transferir ownership a Darwin ─────────────────────────────────────────────
// Esta función resuelve el error "Service Accounts do not have storage quota":
// la SA crea el archivo y de inmediato lo transfiere a Darwin para que el
// almacenamiento cuente contra la cuenta de Darwin (no la SA, que tiene quota 0).
async function transferirOwnership(drive, fileId) {
  try {
    await drive.permissions.create({
      fileId,
      requestBody: {
        role: "owner",
        type: "user",
        emailAddress: DARWIN_EMAIL,
      },
      transferOwnership: true,
      moveToNewOwnersRoot: false, // mantener en la carpeta original
    });
    console.log(`✅ Ownership transferido a ${DARWIN_EMAIL} — fileId: ${fileId}`);
  } catch (err) {
    // No fatal: el archivo existe, solo podría no aparecer en Drive de Darwin
    console.warn(`⚠️  No se pudo transferir ownership de ${fileId}: ${err.message}`);
  }
}

// ── Calcular totales ──────────────────────────────────────────────────────────
function calcTotals(items) {
  const subtotalMat = items.reduce((s, i) => s + i.matTotal, 0);
  const subtotalMO  = items.reduce((s, i) => s + i.moTotal, 0);
  const subtotal    = items.reduce((s, i) => s + i.subtotal, 0);
  const imprevistos = Math.round(subtotal * IMPREVISTOS_PCT);
  const baseImponible = subtotal + imprevistos;
  const iva   = Math.round(baseImponible * IVA);
  const total = baseImponible + iva - 25000;
  return { subtotal, imprevistos, baseImponible, iva, total, subtotalMat, subtotalMO };
}

// ── Formato moneda CR ─────────────────────────────────────────────────────────
function fmtCR(n) {
  return "₡" + Number(n || 0).toLocaleString("es-CR", {
    minimumFractionDigits: 2, maximumFractionDigits: 2,
  });
}

// ── Generar Excel ─────────────────────────────────────────────────────────────
function generarExcel(client, items) {
  const wb = XLSX.utils.book_new();
  const { subtotal, imprevistos, baseImponible, iva, total, subtotalMat, subtotalMO } = calcTotals(items);
  const fecha = new Date().toLocaleDateString("es-CR");

  // Hoja 1: Detalle interno con materiales desglosados
  const rows = [
    ["SS REMODELACIONES — PRESUPUESTO INTERNO"],
    ["Ref:", client.referencia, "Fecha:", fecha, "Cliente:", client.nombre],
    ["Proyecto:", client.asunto],
    [],
    ["Ítem", "Detalle", "Und", "Cantidad", "Precio Unit.", "Subtotal Mat.",
     "Días", "Operarios", "Ayudantes", "MO Base", "Utilidad MO", "Total MO", "TOTAL ACTIVIDAD"],
  ];

  items.forEach(item => {
    rows.push([
      item.id, item.descripcion, "", "", "", "",
      item.dias, item.operarios, item.ayudantes,
      item.moBase, item.moUtilidad, item.moTotal, item.subtotal,
    ]);
    item.materiales.forEach(m => {
      rows.push(["", `  → ${m.detalle} (${m.fuente})`, m.und, m.cantidad,
        m.precio_unitario, m.cantidad * m.precio_unitario]);
    });
    rows.push(["", "Subtotal materiales:", "", "", "", item.matTotal]);
    rows.push([]);
  });

  rows.push(["", "TOTAL MATERIALES", "", "", "", subtotalMat,
             "", "", "", "", "", "TOTAL M.O.", subtotalMO]);

  // Hoja 2: Resumen para cotización
  const resumen = [
    ["Descripción", "Unidad", "Cantidad", "Materiales", "M.O.", "SUB TOTAL"],
    ...items.map(i => [i.descripcion, i.unidad, i.cantidad, i.matTotal, i.moTotal, i.subtotal]),
    [],
    ["", "", "", "", "Sub total", subtotal],
    ["", "", "", "", "Imprevistos 5%", imprevistos],
    ["", "", "", "", "Base imponible", baseImponible],
    ["", "", "", "", "IVA 13%", iva],
    ["", "", "", "", "Reembolso visita", -25000],
    ["", "", "", "", "TOTAL", total],
  ];

  const ws1 = XLSX.utils.aoa_to_sheet(rows);
  const ws2 = XLSX.utils.aoa_to_sheet(resumen);
  ws1["!cols"] = [{ wch: 6 }, { wch: 40 }, { wch: 8 }, { wch: 10 }, { wch: 12 }, { wch: 14 }];
  ws2["!cols"] = [{ wch: 40 }, { wch: 8 }, { wch: 10 }, { wch: 14 }, { wch: 14 }, { wch: 16 }];
  XLSX.utils.book_append_sheet(wb, ws1, "Detalle Interno");
  XLSX.utils.book_append_sheet(wb, ws2, "Resumen Cotizacion");

  return XLSX.write(wb, { type: "buffer", bookType: "xlsx" });
}

